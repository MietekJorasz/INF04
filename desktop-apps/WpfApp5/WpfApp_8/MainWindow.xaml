<Window x:Class="WpfApp_8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp_8"
        mc:Ignorable="d"
        Title="Szyfrowanie. Wykonane przez 00000000000" Height="450" Width="800">
    <Grid Background="CadetBlue">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Foreground="AntiqueWhite" FontSize="20" Text="Podaj wartosc klucza"/>
            <TextBox x:Name="key_TextBox" Width="50" Margin="0 25"/>
            <TextBlock Margin="0 0 0 25" Foreground="AntiqueWhite" FontSize="20" Text="Podaj tekst"/>
            <TextBox AcceptsReturn="True" TextWrapping="Wrap" x:Name="text_TextBox" Height="240" />
            
        </StackPanel>
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="encrypt_Btn" Width="60" Height="30" Content="Zaszyfruj" Background="LightBlue" Click="encrypt_Btn_Click"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="10">
            <TextBlock Foreground="AntiqueWhite" FontSize="20" Text="Tekst zaszyfrowany"/>
            <Border Margin="0 25" BorderBrush="AntiqueWhite" BorderThickness="3" CornerRadius="20" Height="280">
                <TextBlock x:Name="encryptedText_TextBlock" Foreground="AntiqueWhite" FontSize="16" Margin="20"/>
            </Border>
            <Button x:Name="saveEncryption_Btn" Background="LightBlue" Width="200" Height="30" Content="Zapisz szyfr w pliku" Click="saveEncryption_Btn_Click"/>
        </StackPanel>

    </Grid>
</Window>
