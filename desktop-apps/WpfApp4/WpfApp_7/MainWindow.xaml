<Window x:Class="WpfApp_7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp_7"
        mc:Ignorable="d"
        Title="Wzornik kolorów RGB. Wykonał 00000000000" Height="450" Width="800">
    <Grid Background="Cornsilk">
        <StackPanel Margin="50 25">
            <Rectangle x:Name="previewRect" Width="700" Height="100" Fill="White" />
            <TextBlock Width="700" Margin="0 20" Text="Dobierz kolor suwakami i zapisz przyciskiem:"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="R" Width="50"/>
                <Slider x:Name="redSlider" Width="590" Minimum="0" Maximum="255" TickFrequency="1" Value="255" ValueChanged="redSlider_ValueChanged"/>
                <Label x:Name="redLabel" Content="255" Margin="20 0 0 0" Width="30"/>
            </StackPanel>
            <StackPanel Margin="0 25" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="G" Width="50"/>
                <Slider x:Name="greenSlider" Width="590" Minimum="0" Maximum="255" TickFrequency="1" Value="255" ValueChanged="greenSlider_ValueChanged"/>
                <Label x:Name="greenLabel" Content="255" Margin="20 0 0 0" Width="30"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="B" Width="50"/>
                <Slider x:Name="blueSlider" Width="590" Minimum="0" Maximum="255" TickFrequency="1" Value="255" ValueChanged="blueSlider_ValueChanged"/>
                <Label x:Name="blueLabel" Content="255" Margin="20 0 0 0" Width="30"/>
            </StackPanel>
            <Button Background="Peru" x:Name="submitBtn" Content="Pobierz" Width="200" Height="30" Click="submitBtn_Click"/>
            <Label x:Name="colorRGBLabel" Content="255,255,255" Background="White" Width="200" Height="30" Margin="0 20 0 0"/>
        </StackPanel>

    </Grid>
</Window>
