<Window x:Class="WpfApp_6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp_6"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="CadetBlue">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="25" >
            <StackPanel Margin="0 10" Orientation="Horizontal" HorizontalAlignment="Right">
                <Label Content="Numer" Width="60" Margin="0 0 35 0"/>
                <TextBox Background="Azure" x:Name="numberTextBox" Width="250" LostFocus="numberTextBox_LostFocus"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Label Content="Imię" Width="60" Margin="0 0 35 0"/>
                <TextBox Background="Azure" x:Name="fNameTextBox" Width="250"/>
            </StackPanel>
            <StackPanel Margin="0 10" Orientation="Horizontal" HorizontalAlignment="Right">
                <Label Content="Nazwisko" Width="60" Margin="0 0 35 0"/>
                <TextBox Background="Azure" x:Name="lNameTextBox" Width="250"/>
            </StackPanel>
            <GroupBox Header="Kolor oczu" Width="340" HorizontalAlignment="Right">
                <StackPanel Margin="10">
                    <RadioButton x:Name="blueRadioBtn" GroupName="eyeColor" Margin="0 5" Content="niebieskie"/>
                    <RadioButton x:Name="greenRadioBtn" GroupName="eyeColor" Content="zielone"/>
                    <RadioButton x:Name="brownRadioBtn" GroupName="eyeColor" Margin="0 5" Content="piwne"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
        <StackPanel Grid.Column="1">
            <StackPanel Orientation="Horizontal" Margin="35">
                <Image Height="180" Margin="0 0 10 0" x:Name="profileImage"></Image>
                <Image Height="180" x:Name="fingerPrintImage"></Image>
            </StackPanel>
            <Button x:Name="submitBtn" Background="Azure" Width="200" Height="30" Content="OK" Click="submitBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
